#: faceauth-cli/src/main.rs
msgid "cannot determine username for current UID"
msgstr "Benutzername für aktuelle UID konnte nicht ermittelt werden"

#: faceauth-cli/src/main.rs
msgid "'{user}' is already enrolled with /dev/video{camera}; omit --camera to add another batch, or run 'faceauth clear' first to change cameras"
msgstr "'{user}' ist bereits mit /dev/video{camera} registriert; lassen Sie --camera weg, um einen weiteren Batch hinzuzufügen, oder führen Sie zuerst 'faceauth clear' aus, um die Kamera zu wechseln"

#: faceauth-cli/src/main.rs
msgid "enrolling face for '{user}'"
msgstr "Gesicht für '{user}' wird registriert"

#: faceauth-cli/src/main.rs
msgid "look directly at the camera..."
msgstr "Direkt in die Kamera schauen..."

#: faceauth-cli/src/main.rs
msgid "different angle"
msgstr "anderer Winkel"

#: faceauth-cli/src/main.rs
msgid "[{done}/{total}] capturing...{hint}"
msgstr "[{done}/{total}] Aufnahme läuft...{hint}"

#: faceauth-cli/src/main.rs
msgid "capture failed: {error}"
msgstr "Aufnahme fehlgeschlagen: {error}"

#: faceauth-cli/src/main.rs
msgid "[{done}/{total}] too similar ({dist}) - adjust angle and hold still"
msgstr "[{done}/{total}] zu ähnlich ({dist}) - Winkel anpassen und ruhig halten"

#: faceauth-cli/src/main.rs
msgid "enrollment failed: {error}"
msgstr "Registrierung fehlgeschlagen: {error}"

#: faceauth-cli/src/main.rs
msgid "unexpected response from daemon"
msgstr "Unerwartete Antwort vom Daemon"

#: faceauth-cli/src/main.rs
msgid "[{done}/{total}] captured"
msgstr "[{done}/{total}] aufgenommen"

#: faceauth-cli/src/main.rs
msgid "Enrollment successful for '{user}'."
msgstr "Registrierung für '{user}' erfolgreich."

#: faceauth-cli/src/main.rs
msgid "'{user}' please look at the camera ({camera}) ..."
msgstr "'{user}' bitte in die Kamera schauen ({camera}) ..."

#: faceauth-cli/src/main.rs
msgid "authentication successful"
msgstr "Authentifizierung erfolgreich"

#: faceauth-cli/src/main.rs
msgid "authentication failed: {error}"
msgstr "Authentifizierung fehlgeschlagen: {error}"

#: faceauth-cli/src/main.rs
msgid "Model for '{user}' removed."
msgstr "Modell für '{user}' wurde entfernt."

#: faceauth-cli/src/main.rs
msgid "clear failed: {error}"
msgstr "Löschen fehlgeschlagen: {error}"

#: faceauth-cli/src/main.rs
msgid "User"
msgstr "Benutzer"

#: faceauth-cli/src/main.rs
msgid "UID"
msgstr "UID"

#: faceauth-cli/src/main.rs
msgid "Camera index"
msgstr "Kameraindex"

#: faceauth-cli/src/main.rs
msgid "Camera by-id"
msgstr "Kamera nach ID"

#: faceauth-cli/src/main.rs
msgid "Camera by-path"
msgstr "Kamera nach Pfad"

#: faceauth-cli/src/main.rs
msgid "Batches"
msgstr "Batches"

#: faceauth-cli/src/main.rs faceauth-cli/src/camera.rs
msgid "no camera devices found"
msgstr "Keine Kamerageräte gefunden"

#: faceauth-cli/src/camera.rs
msgid "IR, recommended"
msgstr "IR, empfohlen"

#: faceauth-cli/src/camera.rs
msgid "possible IR"
msgstr "möglicherweise IR"

#: faceauth-cli/src/camera.rs
msgid "(unknown)"
msgstr "(unbekannt)"

#: faceauth-cli/src/camera.rs
msgid "Available cameras:"
msgstr "Verfügbare Kameras:"

#: faceauth-cli/src/camera.rs
msgid "Select camera (default {index}): "
msgstr "Kamera auswählen (Standard {index}): "

#: faceauth-cli/src/camera.rs
msgid "invalid selection '{input}'; expected one of: {options}"
msgstr "Ungültige Auswahl '{input}'; erwartet eines von: {options}"

#: faceauth-cli/src/camera.rs
msgid "--camera is required in non-interactive mode"
msgstr "--camera ist im nicht-interaktiven Modus erforderlich"

#: faceauth-cli/src/camera.rs
msgid "could not resolve camera path '{path}'"
msgstr "Kamerapfad '{path}' konnte nicht aufgelöst werden"

#: faceauth-cli/src/camera.rs
msgid "'{spec}' is ambiguous - matches: {matches}; use a full path instead (e.g. --camera /dev/video{example})"
msgstr "'{spec}' ist mehrdeutig - Treffer: {matches}; stattdessen vollständigen Pfad verwenden (z. B. --camera /dev/video{example})"

#: faceauth-cli/src/camera.rs
msgid "unrecognised camera '{spec}'; use an index, /dev/videoN path, or udev name"
msgstr "Unbekannte Kamera '{spec}'; bitte Index, /dev/videoN-Pfad oder udev-Namen verwenden"

#: faceauth-cli/src/main.rs
msgid "capture failed: invalid encoding from daemon"
msgstr "Aufnahme fehlgeschlagen: Ungültige Kodierung vom Daemon"

#: faceauth-cli/src/main.rs
msgid "capture failed: unexpected response from daemon"
msgstr "Aufnahme fehlgeschlagen: Unerwartete Antwort vom Daemon"

#: faceauth-notify/src/main.rs
msgid "Face Authentication ..."
msgstr "Gesichtserkennung ..."

#: faceauth-notify/src/main.rs
msgid "Requested by: {service}"
msgstr "Angefordert von: {service}"

#: faceauth-notify/src/main.rs
msgid "Requested by: {service} via {caller}"
msgstr "Angefordert von: {service} über {caller}"

#: faceauth-notify/src/main.rs
msgid "Face Authentication Successful"
msgstr "Gesichtserkennung erfolgreich"

#: faceauth-notify/src/main.rs
msgid "Face Authentication Failed"
msgstr "Gesichtserkennung fehlgeschlagen"
